{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Port=3307;Database=demo;User=admin;Password=123456;"
  },
  "Jwt": {
    "Issuer": "Demo",
    "Audience": "Demo",
    "SigningKey": "development-signing-key-change-me-minimum-32",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  },
  "Database": {
    "EnsureCreatedOnStartup": false,
    "SeedOnStartup": false
  },
  "Redis": {
    "Host": "localhost",
    "Port": 6379,
    "Password": null,
    "UseSsl": false,
    "ConnectTimeoutSeconds": 5,
    "SyncTimeoutSeconds": 5,
    "InstanceName": "demo:"
  },
  "Caching": {
    "PermissionEntrySeconds": 300,
    "AgentDetailSeconds": 300,
    "AgentListSeconds": 120,
    "TenantListSeconds": 600,
    "TenantDetailSeconds": 600,
    "KnowledgeExplorerSeconds": 120,
    "NamespaceVersionSeconds": 604800
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext"
    ],
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "AllowedHosts": "*"
}
